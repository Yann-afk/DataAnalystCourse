import pandas as pd
import numpy as np

# Memuat dataset
df = pd.read_csv('Buku1.csv')

# 1. Hapus Duplikat
# Menghilangkan baris yang identik agar tidak merusak perhitungan
df.drop_duplicates(inplace=True)

# 2. Tangani Missing Values (Data Kosong)
# Mengisi Quantity yang kosong dengan 0
df['Quantity'] = df['Quantity'].fillna(0)
# Mengisi UnitPrice yang kosong dengan nilai rata-rata (mean)
df['UnitPrice'] = df['UnitPrice'].fillna(df['UnitPrice'].mean())
# Mengisi TotalPrice yang kosong dengan 0
df['TotalPrice'] = df['TotalPrice'].fillna(0)

# 3. Standarisasi Format
# Menyeragamkan teks pada kolom Region dan Product (huruf kapital di awal, tanpa spasi berlebih)
df['Region'] = df['Region'].astype(str).str.strip().str.title()
df['Product'] = df['Product'].astype(str).str.strip().str.title()
# Contoh spesifik: Jika ada 'Jkt' ingin diubah semua ke 'Jakarta'
# df['Region'] = df['Region'].replace(['Jkt', 'JKT'], 'Jakarta')

# 4. Hapus Outlier yang Salah
# Contoh: Jika ada UnitPrice yang tidak masuk akal (misal > 10.000 atau < 0)
# Kita hanya mengambil data dengan harga yang wajar
df = df[(df['UnitPrice'] > 0) & (df['UnitPrice'] < 10000)]

# 5. Perbaiki Tipe Data
# Memastikan kolom numerik benar-benar terbaca sebagai angka
df['Quantity'] = pd.to_numeric(df['Quantity'], errors='coerce')
df['UnitPrice'] = pd.to_numeric(df['UnitPrice'], errors='coerce')
# Memperbaiki tipe data tanggal
df['Date'] = pd.to_datetime(df['Date'], errors='coerce')

# Simpan hasil
df.to_csv('Data_Cleaned_Format.csv', index=False)

print("Proses cleaning selesai!")
print(df.info())